{
  "name": "hello-world",
  "version": "1.0.0",
  "type": "module",
  "bin": {
    "hello-world": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --treeshake",
    "start": "node dist/index.js",
    "dev": "tsx --watch src/index.ts",
    "test": "vitest run",
    "lint": "biome check src/ tests/",
    "format": "biome format --write src/ tests/"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  },
  "dependencies": {
    "pino": "^10.3.1"
  }
}
