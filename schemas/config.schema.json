{
  // Exolith configuration schema descriptor.
  // Defines the shape of exolith.json for runtime validation.
  // Supports JSON5: comments, trailing commas, unquoted keys.
  "properties": {
    "model": { "type": "string" },
    "maxSourceSize": { "type": "number", "optional": true },
    "reasoningLevel": { "type": "enum", "values": ["off", "low", "medium", "high", "max"], "optional": true },
  },
}
