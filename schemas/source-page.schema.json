{
  // SourcePage structured output schema.
  // Defines the expected JSON shape for LLM source page extraction.
  // Supports JSON5: comments, trailing commas, unquoted keys.
  "type": "object",
  "properties": {
    "title": { "type": "string" },
    "tldr": { "type": "string", "description": "A single sentence capturing the core point of this source." },
    "type": { "type": "string", "enum": ["article", "paper", "transcript", "note", "book"] },
    "authors": { "type": "array", "items": { "type": "string" } },
    "date": { "type": "string" },
    "reference": { "type": "string" },
    "summary": { "type": "string" },
    "mainPoints": { "type": "array", "items": { "type": "string" } },
    "tags": { "type": "array", "items": { "type": "string" } },
  },
  "required": ["title", "tldr", "type", "authors", "date", "summary", "mainPoints", "tags"],
  "additionalProperties": false,
}
